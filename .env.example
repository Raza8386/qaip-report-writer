# ─────────────────────────────────────────────────────────────
#  QAIP Report Writer — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── Optional ──────────────────────────────────────────────────
# Server port (default: 3000)
PORT=3000

# Host binding:
#   localhost  = only accessible on this machine (development)
#   0.0.0.0   = accessible from network (production/office use)
HOST=localhost
